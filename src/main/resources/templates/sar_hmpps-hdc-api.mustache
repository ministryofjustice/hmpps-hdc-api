{{#*inline "licenceDetails"}}
<h4>Licence eligibility</h4>
{{#eligibility}}
<table class="data-table">
    <tr>
        <td class="data-column-25">Insufficient time prior to CRD</td>
        <td class="data-column-25">Excluded</td>
        <td class="data-column-25">Suitability</td>
        <td class="data-column-25"></td>
    </tr>
    <tr>
        <td>{{ optionalValue crdTime.decision }}</td>
        <td>{{ optionalValue excluded.decision }}</td>
        <td>{{ optionalValue suitability.decision }}</td>
        <td></td>
    </tr>
</table>
{{/eligibility}}
{{^eligibility}}
    <p>No Data Held</p>
{{/eligibility}}

<br>
<h4>Bass referral</h4>
{{#bassReferral}}
    <table class="summary-list">
        <tr><td>Bass requested</td><td>{{ optionalValue bassRequest.bassRequested }}</td></tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-20">Bass offer accepted</td>
            <td class="data-column-20">Address line 1</td>
            <td class="data-column-20">Address line 2</td>
            <td class="data-column-20">Town / City</td>
            <td class="data-column-20">Postcode</td>
        </tr>
        <tr>
            <td>{{ optionalValue bassOffer.bassAccepted }}</td>
            <td>{{ optionalValue bassOffer.addressLine1 }}</td>
            <td>{{ optionalValue bassOffer.addressLine2 }}</td>
            <td>{{ optionalValue bassOffer.addressTown }}</td>
            <td>{{ optionalValue bassOffer.postCode }}</td>
        </tr>
    </table>
{{/bassReferral}}
{{^bassReferral}}
    <p>No Data Held</p>
{{/bassReferral}}

<br>
<h4>Proposed address</h4>
{{#proposedAddress}}
<table class="data-table">
    <tr>
        <td class="data-column-25">Address line 1</td>
        <td class="data-column-25">Address line 2</td>
        <td class="data-column-25">Town / City</td>
        <td class="data-column-25">Postcode</td>
    </tr>
    <tr>
        <td>{{ optionalValue curfewAddress.addressLine1 }}</td>
        <td>{{ optionalValue curfewAddress.addressLine2 }}</td>
        <td>{{ optionalValue curfewAddress.addressTown }}</td>
        <td>{{ optionalValue curfewAddress.postCode }}</td>
    </tr>
</table>
{{/proposedAddress}}
{{^proposedAddress}}
    <p>No Data Held</p>
{{/proposedAddress}}

<br>
<h4>Curfew</h4>
{{#curfew}}
    <table class="summary-list">
        <tr><td>First night curfew hours</td><td>{{ optionalValue (formatDate firstNight.firstNightFrom) }} - {{ optionalValue (formatDate firstNight.firstNightUntil) }}</td></tr>
    </table>

     <h5>Curfew hours</h5>
    <table class="data-table">
        <tr>
            <td class="data-column-14">Day</td>
            <td>Curfew hours</td>
        </tr>
        <tr>
            <td class="data-column-14">Monday</td>
            <td>{{ optionalValue curfewHours.mondayFrom }} - {{ optionalValue curfewHours.mondayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-14">Tuesday</td>
            <td>{{ optionalValue curfewHours.tuesdayFrom }} - {{ optionalValue curfewHours.tuesdayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-20">Wednesday</td>
            <td>{{ optionalValue curfewHours.wednesdayFrom }} - {{ optionalValue curfewHours.wednesdayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-14">Thursday</td>
            <td>{{ optionalValue curfewHours.thursdayFrom }} - {{ optionalValue curfewHours.thursdayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-14">Friday</td>
            <td>{{ optionalValue curfewHours.fridayFrom }} - {{ optionalValue curfewHours.fridayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-14">Saturday</td>
            <td>{{ optionalValue curfewHours.saturdayFrom }} - {{ optionalValue curfewHours.saturdayUntil }}</td>
        </tr>
        <tr>
            <td class="data-column-14">Sunday</td>
            <td>{{ optionalValue curfewHours.sundayFrom }} - {{ optionalValue curfewHours.sundayUntil }}</td>
        </tr>
    </table>

    <h5>Approved Premises</h5>
    <table class="data-table">
        <tr>
            <td class="data-column-20">Required</td>
            <td class="data-column-20">Address line 1</td>
            <td class="data-column-20">Address line 2</td>
            <td class="data-column-20">Town / City</td>
            <td class="data-column-20">Postcode</td>
        </tr>
        <tr>
            <td>{{ optionalValue approvedPremises.required }}</td>
            <td>{{ optionalValue approvedPremisesAddress.addressLine1 }}</td>
            <td>{{ optionalValue approvedPremisesAddress.addressLine2 }}</td>
            <td>{{ optionalValue approvedPremisesAddress.addressTown }}</td>
            <td>{{ optionalValue approvedPremisesAddress.postCode }}</td>
        </tr>
    </table>
{{/curfew}}
{{^curfew}}
    <p>No Data Held</p>
{{/curfew}}

<br>
<h4>Risk</h4>
{{#risk}}
    <table class="data-table">
        <tr>
            <td class="data-column-25">Version</td>
            <td class="data-column-25">EMS information</td>
            <td class="data-column-50">EMS information details</td>
        </tr>
        <tr>
            <td>{{ optionalValue riskManagement.version }}</td>
            <td>{{ optionalValue riskManagement.emsInformation }}</td>
            <td>{{ optionalValue riskManagement.emsInformationDetails }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-25">Has considered checks</td>
            <td class="data-column-25">Awaiting other information</td>
            <td class="data-column-50">Risk management details</td>
        </tr>
        <tr>
            <td>{{ optionalValue riskManagement.hasConsideredChecks }}</td>
            <td>{{ optionalValue riskManagement.awaitingOtherInformation }}</td>
            <td>{{ optionalValue riskManagement.riskManagementDetails }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-25">POM consultation</td>
            <td class="data-column-25">Non-disclosable information</td>
            <td class="data-column-50">Non-disclosable information details</td>
        </tr>
        <tr>
            <td>{{ optionalValue riskManagement.pomConsultation }}</td>
            <td>{{ optionalValue riskManagement.nonDisclosableInformation }}</td>
            <td>{{ optionalValue riskManagement.nonDisclosableInformationDetails }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-25">Mental health plan</td>
            <td class="data-column-25">Proposed address suitable</td>
            <td class="data-column-50">Unsuitable reason</td>
        </tr>
        <tr>
            <td>{{ optionalValue riskManagement.mentalHealthPlan }}</td>
            <td>{{ optionalValue riskManagement.proposedAddressSuitable }}</td>
            <td>{{ optionalValue riskManagement.unsuitableReason }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-30">Manage in the community</td>
            <td class="data-column-70">Manage in the community not possible reason</td>
        </tr>
        <tr>
            <td>{{ optionalValue riskManagement.manageInTheCommunity }}</td>
            <td>{{ optionalValue riskManagement.manageInTheCommunityNotPossibleReason }}</td>
        </tr>
    </table>
{{/risk}}
{{^risk}}
    <p>No Data Held</p>
{{/risk}}

<br>
<h4>Reporting instructions</h4>
{{#reporting}}
    <table class="data-table">
        <tr>
            <td class="data-column-25">Name</td>
            <td class="data-column-25">Telephone</td>
            <td class="data-column-50">Organisation</td>
        </tr>
        <tr>
            <td>{{ optionalValue reportingInstructions.name }}</td>
            <td>{{ optionalValue reportingInstructions.telephone }}</td>
            <td>{{ optionalValue reportingInstructions.organisation }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-25">Building and street 1</td>
            <td class="data-column-25">Town / City</td>
            <td class="data-column-50">Reporting date</td>
        </tr>
        <tr>
            <td>{{ optionalValue reportingInstructions.buildingAndStreet1 }}</td>
            <td>{{ optionalValue reportingInstructions.townOrCity }}</td>
            <td>{{ optionalValue (formatDate reportingInstructions.reportingDate) }}</td>
        </tr>
    </table>
    <table class="data-table">
        <tr>
            <td class="data-column-25">Building and street 2</td>
            <td class="data-column-25">Postcode</td>
            <td class="data-column-50">Reporting time</td>
        </tr>
        <tr>
            <td>{{ optionalValue reportingInstructions.buildingAndStreet2 }}</td>
            <td>{{ optionalValue reportingInstructions.postcode }}</td>
            <td>{{ optionalValue (formatDate reportingInstructions.reportingTime) }}</td>
        </tr>
    </table>
{{/reporting}}
{{^reporting}}
    <p>No Data Held</p>
{{/reporting}}

<br>
<h4>Victim Liaison</h4>
{{#victim}}
    <table class="summary-list">
        <tr><td>Decision</td><td>{{ optionalValue victimLiaison.decision }}</td></tr>
    </table>
{{/victim}}
{{^victim}}
    <p>No Data Held</p>
{{/victim}}

<br>
<h4>Licence conditions</h4>
{{#licenceConditions}}
    <h5>Bespoke conditions</h5>
    {{#bespokeConditions}}
    <table class="summary-list">
        <tr>
            <td>Text</td>
            <td>{{optionalValue text}}</td>
        </tr>
        <tr>
            <td>Approved</td>
            <td>{{optionalValue approved}}</td>
        </tr>
    </table>
    {{/bespokeConditions}}
    {{^bespokeConditions}}
        <p>No Data Held</p>
    {{/bespokeConditions}}
    <table class="summary-list">
        <tr><td>Additional conditions required</td><td>{{ optionalValue standard.additionalConditionsRequired }}</td></tr>
        <tr><td>Additional conditions justification</td><td>{{ optionalValue additionalConditionsJustification }}</td></tr>
    </table>
    <h5>Additional conditions</h5>
    <table class="summary-list">
    {{#additionalConditions}}
            <tr>
              <td>{{conditionCode}}</td>
              <td>{{renderedText}}</td>
            </tr>
    {{/additionalConditions}}
         </table>
    {{^additionalConditions}}
        <p>No Data Held</p>
    {{/additionalConditions}}
{{/licenceConditions}}
{{^licenceConditions}}
    <p>No Data Held</p>
{{/licenceConditions}}

<br>
<h4>Document Template</h4>
{{#document}}
    <table class="summary-list">
        <tr><td>Decision</td><td>{{ optionalValue template.decision }}</td></tr>
        <tr><td>Offence committed before Feb 2015</td><td>{{ optionalValue template.offenceCommittedBeforeFeb2015 }}</td></tr>
    </table>
{{/document}}
{{^document}}
    <p>No Data Held</p>
{{/document}}

<br>
<h4>Approval: Release</h4>
{{#approval}}
    <table class="summary-list">
        <tr><td>Decision</td><td>{{ optionalValue release.decision }}</td></tr>
        <tr><td>Decision maker</td><td>{{ optionalValue release.decisionMaker }}</td></tr>
        <tr><td>Reason for decision</td><td>{{ optionalValue release.reasonForDecision }}</td></tr>
    </table>
{{/approval}}
{{^approval}}
    <p>No Data Held</p>
{{/approval}}

<br>
<h4>Final checks</h4>
{{#finalChecks}}
<table class="data-table">
    <tr>
        <td class="data-column-33">On remand decision</td>
        <td class="data-column-33">Serious offence decision</td>
        <td class="data-column-33">Confiscation order decision</td>
    </tr>
    <tr>
        <td>{{ optionalValue onRemand.decision }}</td>
        <td>{{ optionalValue seriousOffence.decision }}</td>
        <td>{{ optionalValue confiscationOrder.decision }}</td>
    </tr>
</table>
{{/finalChecks}}
{{^finalChecks}}
    <p>No Data Held</p>
{{/finalChecks}}
{{/inline}}

<h1 class="title">Home Detention Curfew</h1>
{{#.}}
    <h2>Licences</h2>
    {{#licences}}
        <h3>Licence</h3>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Id</td>
                <td class="data-column-30">Deleted at</td>
                <td class="data-column-30">Stage</td>
                <td class="data-column-30">Version</td>
                <td class="data-column-30">Vary version</td>
            </tr>
            <tr>
                <td>{{ optionalValue licenceId }}</td>
                <td>{{ optionalValue (formatDate deletedAt) }}</td>
                <td>{{ optionalValue stage }}</td>
                <td>{{ optionalValue version }}</td>
                <td>{{ optionalValue varyVersion }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Transition date</td>
                <td class="data-column-30">Additional conditions version</td>
                <td class="data-column-30">Standard conditions version</td>
            </tr>
            <tr>
                <td>{{ optionalValue (formatDate transitionDate) }}</td>
                <td>{{ optionalValue additionalConditionsVersion }}</td>
                <td>{{ optionalValue standardConditionsVersion }}</td>
            </tr>
        </table>

        {{#licence}}
            <br>
            {{>licenceDetails}}
        {{/licence}}

    {{/licences}}

    <br>
    <h2>Licence versions</h2>
    {{#licenceVersions}}
        <h3>Licence version</h3>
        <table class="data-table">
            <tr>
                <td class="data-column-30">Id</td>
                <td class="data-column-25">Created</td>
                <td class="data-column-30">Deleted at</td>
                <td class="data-column-25">Version</td>
                <td class="data-column-25">Template</td>
                <td class="data-column-25">Vary version</td>
            </tr>
            <tr>
                <td>{{ optionalValue licenceVersionId }}</td>
                <td>{{ optionalValue (formatDate timestamp) }}</td>
                <td>{{ optionalValue (formatDate deletedAt) }}</td>
                <td>{{ optionalValue version }}</td>
                <td>{{ optionalValue template }}</td>
                <td>{{ optionalValue varyVersion }}</td>
            </tr>
        </table>

        {{#licence}}
        {{>licenceDetails}}
        {{/licence}}

    {{/licenceVersions}}
    <br>
{{/.}}
